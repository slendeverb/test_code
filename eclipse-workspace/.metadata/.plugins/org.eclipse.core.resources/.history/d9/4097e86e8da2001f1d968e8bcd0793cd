package SimpleOS.Simulation;
	
import java.util.LinkedList;
import java.util.PriorityQueue;

public class OS {
	
	private OS() {}
	
	public static OS getInstance() {
		return Singleton.INSTANCE.getInstance();
	}
	
	private enum Singleton{
		INSTANCE;
		private OS instance;
		Singleton() {
			instance=new OS();
		}
		public OS getInstance() {
			return instance;
		}
	}
	
	public static String run() {
		return "Operating System Running...";
	}
	
	public static String stop() {
		readyQueue.clear();
		blockQueue.clear();
		return "Operating System Stopping...";
	}
	
	public static void block(Process process) {
		if(readyQueue.isEmpty()) {
			return;
		}
		readyQueue.remove(process);
		process.block(blockQueue);
	}
	
	public static void wakeup() {
		if(blockQueue.isEmpty()) {
			return;
		}
		Process process=blockQueue.removeFirst();
		process.pcb.state=State.READY;
		readyQueue.add(process);
	}
	
	public static void suspend() {
		
	}
	
	public static void active() {
		
	}

	private static long systemTime=0;
	private static LinkedList<Process> blockQueue=new LinkedList<Process>();
	private static PriorityQueue<Process> readyQueue=new PriorityQueue<Process>();
	private static LinkedList<Process> suspendQueue=new LinkedList<Process>();
}
