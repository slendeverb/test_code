package SimpleOS;

import org.eclipse.swt.widgets.Display;
import org.eclipse.swt.widgets.Shell;
import org.eclipse.swt.widgets.Label;
import org.eclipse.swt.SWT;
import org.eclipse.swt.widgets.Text;
import org.eclipse.swt.widgets.Button;
import org.eclipse.swt.events.MouseAdapter;
import org.eclipse.swt.events.MouseEvent;

public class CreateProcess {

	protected Shell shell;
	private Text textProcessID;
	private Text textPriority;
	private Text textMemoryNeed;

	/**
	 * Launch the application.
	 * @param args
	 */
	public static void main(String[] args) {
		try {
			CreateProcess window = new CreateProcess();
			window.open();
		} catch (Exception e) {
			e.printStackTrace();
		}
	}

	/**
	 * Open the window.
	 */
	public void open() {
		Display display = Display.getDefault();
		createContents();
		shell.open();
		shell.layout();
		while (!shell.isDisposed()) {
			if (!display.readAndDispatch()) {
				display.sleep();
			}
		}
	}

	/**
	 * Create contents of the window.
	 */
	protected void createContents() {
		shell = new Shell();
		shell.setSize(450, 338);
		shell.setText("创建进程");
		shell.setLocation(Display.getCurrent().getClientArea().width/2-shell.getSize().x/2,
				Display.getCurrent().getClientArea().height/2-shell.getSize().y/2);
		
		Label lblProcessID = new Label(shell, SWT.NONE);
		lblProcessID.setBounds(45, 51, 92, 20);
		lblProcessID.setText("进程ID");
		lblProcessID.setAlignment(SWT.CENTER);
		
		Label lblPriority = new Label(shell, SWT.NONE);
		lblPriority.setBounds(45, 114, 92, 20);
		lblPriority.setText("优先级");
		lblPriority.setAlignment(SWT.CENTER);
		
		Label lblMemoryNeed = new Label(shell, SWT.NONE);
		lblMemoryNeed.setBounds(45, 177, 92, 20);
		lblMemoryNeed.setText("所需内存(K)");
		lblMemoryNeed.setAlignment(SWT.CENTER);
		
		textProcessID = new Text(shell, SWT.BORDER);
		textProcessID.setBounds(143, 51, 238, 26);
		
		textPriority = new Text(shell, SWT.BORDER);
		textPriority.setBounds(143, 114, 238, 26);
		
		textMemoryNeed = new Text(shell, SWT.BORDER);
		textMemoryNeed.setBounds(143, 177, 238, 26);
		
		Label lblPleaseInput = new Label(shell, SWT.NONE);
		lblPleaseInput.setBounds(10, 10, 76, 20);
		lblPleaseInput.setText("请输入: ");
		
		Button btnConfirm = new Button(shell, SWT.NONE);
		btnConfirm.addMouseListener(new MouseAdapter() {
			@Override
			public void mouseUp(MouseEvent e) {
				
			}
		});
		btnConfirm.setBounds(80, 236, 98, 30);
		btnConfirm.setText("确定");
		
		Button btnCancel = new Button(shell, SWT.NONE);
		btnCancel.addMouseListener(new MouseAdapter() {
			@Override
			public void mouseUp(MouseEvent e) {
				shell.dispose();
			}
		});
		btnCancel.setBounds(250, 236, 98, 30);
		btnCancel.setText("取消");

	}
}
